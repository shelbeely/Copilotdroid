# Built application files
*.apk
*.aar
*.ap_
*.aab

# Files for the ART/Dalvik VM
*.dex

# Java class files
*.class

# Generated files
bin/
gen/
out/
release/

# Gradle files
.gradle/
build/
app/build/

# Local configuration file (sdk path, etc)
local.properties

# Proguard folder generated by Eclipse
proguard/

# Log Files
*.log

# Android Studio Navigation editor temp files
.navigation/

# Android Studio captures folder
captures/

# IntelliJ
*.iml
.idea/
*.iws
*.ipr

# Keystore files
# The shared debug keystore (app/debug.keystore) is intentionally tracked in
# version control so every developer and CI machine builds debug APKs with the
# same signing certificate.  Without a shared key, Android rejects updates
# with "App not installed" when the installed APK was signed on a different
# machine.  Release keystores must never be committed.
*.jks
*.keystore
!app/debug.keystore

# External native build folder generated in Android Studio 2.2 and later
.externalNativeBuild
.cxx/

# Google Services (e.g. APIs or Firebase)
google-services.json

# Version control
vcs.xml

# lint
lint/intermediates/
lint/generated/
lint/outputs/
lint/tmp/
lint/reports/

# MacOS
.DS_Store
